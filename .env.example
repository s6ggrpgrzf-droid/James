# Stripe secret key — from https://dashboard.stripe.com/apikeys
# Use sk_live_... in production, sk_test_... for development
STRIPE_SECRET_KEY=sk_live_...

# Token signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 random bytes. Never reuse across environments.
TOKEN_SECRET=your-random-secret-here
